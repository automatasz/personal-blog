---
import { actions } from "astro:actions";
import { daysAgo, daysAgoWord, getTime } from "@utils/date-utils";

const result = await Astro.callAction(actions.getBatches, null);
const { error, data } = result;
---

<section class="space-y-4">
{
  error ? (
    <div class="card-base rounded-xl px-6 py-4 text-red-600 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <span>Error when displaying finished batches: {(error as { message: string }).message}.</span>
    </div>
  ) : data && data.length === 0 ? (
    <div class="card-base rounded-xl px-6 py-8 text-center">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-30">
        <path d="M22 12h-6l-2 3H10l-2-3H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>
      </svg>
      <p class="text-50 mt-2">Once you upload some images, the results can be accessed from this page.</p>
    </div>
  ) : data ? (
    <>
      <h3 class="font-heading font-bold text-xl text-90">Batches created so far</h3>
      <div class="grid gap-3">
        {
          data.map((batch) => {
            const created = new Date(batch.created_at);
            return (
              <a
                href={`/batch?id=${batch.id}`}
                title={created.toLocaleString()}
                class="group card-base rounded-xl px-5 py-4 flex items-center justify-between gap-4 hover:scale-[1.01] hover:shadow-md transition-all duration-300"
              >
                <div class="min-w-0">
                  <div class="font-heading font-semibold text-base text-75 truncate">
                    {batch.title ?? "Untitled batch"}
                  </div>
                  <div class="flex items-center gap-3 mt-1.5">
                    <span class="inline-flex items-center gap-1 text-sm font-medium text-50">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                      </svg>
                      {Number(batch.number_of_images)} {Number(batch.number_of_images) === 1 ? "image" : "images"}
                    </span>
                    <span class="text-30 text-sm">|</span>
                    <span class="text-sm text-30">
                      {daysAgoWord(daysAgo(created))} {getTime(created)}
                    </span>
                  </div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-30 group-hover:text-50 group-hover:translate-x-0.5 transition-all duration-300 shrink-0">
                  <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
              </a>
            );
          })
        }
      </div>
    </>
  ) : null
}
</section>