---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import KeyworderSvelte from "@components/Keyworder.svelte";
import BatchList from "@components/BatchList.astro";
import StatsGrid from "@components/StatsGrid.astro";

export const prerender = false;
---

<MainGridLayout description={i18n(I18nKey.keyworder)} title={i18n(I18nKey.keyworder)}>
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-8 relative w-full">
      <!-- Hero -->
      <div class="absolute inset-0 rounded-[var(--radius-large)] overflow-hidden pointer-events-none">
        <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-[var(--primary)]/[0.03] blur-3xl"></div>
        <div class="absolute -bottom-16 -left-16 w-64 h-64 rounded-full bg-[var(--primary)]/[0.02] blur-3xl"></div>
      </div>
      <div class="relative">
        <h1 class="text-90 text-3xl font-heading font-black tracking-tight">
          Keyworder
        </h1>
        <p class="text-75 mt-2 max-w-2xl">
          Upload images and generate AI-powered descriptions with rich keywords. Perfect for photo stock websites, blog posts, or personal galleries.
        </p>

        <!-- Steps -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 my-7">
          <div class="card-base rounded-xl px-4 py-4 flex flex-col gap-2">
            <div class="w-8 h-8 rounded-lg bg-[var(--primary)]/10 flex items-center justify-center">
              <span class="text-base font-heading font-bold text-[var(--primary)]">1</span>
            </div>
            <div>
              <p class="font-heading font-semibold text-base text-90">Choose files</p>
              <p class="text-sm text-50 mt-0.5">Select images from your device</p>
            </div>
          </div>
          <div class="card-base rounded-xl px-4 py-4 flex flex-col gap-2">
            <div class="w-8 h-8 rounded-lg bg-[var(--primary)]/10 flex items-center justify-center">
              <span class="text-base font-heading font-bold text-[var(--primary)]">2</span>
            </div>
            <div>
              <p class="font-heading font-semibold text-base text-90">Review</p>
              <p class="text-sm text-50 mt-0.5">Check selected images, remove unwanted</p>
            </div>
          </div>
          <div class="card-base rounded-xl px-4 py-4 flex flex-col gap-2">
            <div class="w-8 h-8 rounded-lg bg-[var(--primary)]/10 flex items-center justify-center">
              <span class="text-base font-heading font-bold text-[var(--primary)]">3</span>
            </div>
            <div>
              <p class="font-heading font-semibold text-base text-90">Describe</p>
              <p class="text-sm text-50 mt-0.5">AI generates title, description & keywords</p>
            </div>
          </div>
          <div class="card-base rounded-xl px-4 py-4 flex flex-col gap-2">
            <div class="w-8 h-8 rounded-lg bg-[var(--primary)]/10 flex items-center justify-center">
              <span class="text-base font-heading font-bold text-[var(--primary)]">4</span>
            </div>
            <div>
              <p class="font-heading font-semibold text-base text-90">Export</p>
              <p class="text-sm text-50 mt-0.5">Copy keywords or download as CSV</p>
            </div>
          </div>
        </div>
      </div>

      <StatsGrid server:defer>
        <div slot="fallback" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          {[0, 1, 2, 3].map(() => (
            <div class="card-base rounded-xl px-5 py-5 flex items-center gap-4">
              <div class="w-11 h-11 rounded-xl bg-[var(--btn-plain-bg-hover)] animate-pulse shrink-0"></div>
              <div class="space-y-2">
                <div class="h-3.5 w-14 rounded bg-[var(--btn-plain-bg-hover)] animate-pulse"></div>
                <div class="h-6 w-10 rounded bg-[var(--btn-plain-bg-hover)] animate-pulse"></div>
              </div>
            </div>
          ))}
        </div>
      </StatsGrid>
      <KeyworderSvelte client:load />
      <div class="mt-12">
        <BatchList server:defer>
          <div slot="fallback" class="flex justify-center py-8">
            <svg class="text-2xl text-[var(--primary)] animate-spin" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
            </svg>
          </div>
        </BatchList>
      </div>
    </div>
  </div>
</MainGridLayout>
