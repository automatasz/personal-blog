{
  "name": "fuwari",
  "compatibility_date": "2025-05-24",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [{
    "binding": "DB",
    "database_name": "fuwari-db",
    "database_id": "placeholder"
  }],
  "queues": {
    "producers": [{
      "queue": "image-describe",
      "binding": "IMAGE_QUEUE"
    }]
  }
}
